.container {
  padding: 0;
  background-color: #f8f5e9;
  min-height: 100vh;
}

/* 页面头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left {
  width: 80rpx;
}

.back-icon {
  font-size: 32rpx;
  color: #333;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.header-right {
  width: 80rpx;
  text-align: right;
}

.save-btn {
  font-size: 28rpx;
  color: #d4a76a;
  font-weight: 500;
}

/* 表单内容 */
.form-content {
  background-color: #fff;
  margin-top: 20rpx;
}

/* 表单项 */
.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  width: 150rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  text-align: right;
  padding-right: 20rpx;
}

.form-textarea {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  min-height: 120rpx;
  padding: 10rpx 20rpx 10rpx 0;
  text-align: right;
  line-height: 1.5;
}

/* 所在地区选择 */
.region-select {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 20rpx;
}

.region-text {
  font-size: 28rpx;
  color: #666;
  margin-right: 10rpx;
  text-align: right;
}

.region-arrow {
  font-size: 24rpx;
  color: #999;
}

/* 复选框 */
.checkbox-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.checkbox-container {
  padding-right: 20rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.checkbox.checked {
  background-color: #d4a76a;
  border-color: #d4a76a;
}

.checkbox-icon {
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
}

/* 输入框占位符样式 */
input::placeholder,
textarea::placeholder {
  color: #999;
  font-size: 28rpx;
}
