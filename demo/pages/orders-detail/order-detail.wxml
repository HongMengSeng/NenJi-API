<view class="container">
  <!-- 商品图片 -->
  <view class="goods-image-container">
    <image class="goods-image" src="{{goods.image}}" mode="aspectFit" />
  </view>

  <!-- 商品信息 -->
  <view class="goods-info-section">
    <view class="price">¥{{goods.price}}</view>
    <view class="goods-name">{{goods.name}}</view>
    <view class="goods-desc">{{goods.desc}}</view>
    
    <!-- 服务信息 -->
    <view class="service-info">
      <view class="service-item">
        <text class="service-label">服务：</text>
        <text class="service-value">称重退差价</text>
      </view>
    </view>
  </view>

  <!-- 商品详情 -->
  <view class="goods-detail-section">
    <view class="section-title">商品详情</view>
    <view class="detail-content">
      <image class="detail-image" src="{{goods.detailImage}}" mode="aspectFit" />
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="cart-icon" bindtap="viewCart">
      <text class="cart-text">🛒</text>
      <block wx:if="{{cartCount > 0}}">
        <view class="cart-badge">{{cartCount}}</view>
      </block>
    </view>
    <view class="action-buttons">
      <button class="add-to-cart-btn" bindtap="addToCart">加入购物车</button>
      <button class="buy-now-btn" bindtap="buyNow">立即购买</button>
    </view>
  </view>
</view>