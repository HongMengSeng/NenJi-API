.page {
  min-height: 100vh;
  background: #f6f6f6;
}

.detail-swiper {
  width: 100%;
  height: 420rpx;
  background: #eeeeee;
}

.detail-swiper-image {
  width: 100%;
  height: 100%;
  display: block;
}

.detail-swiper-video {
  width: 100%;
  height: 100%;
  display: block;
}

.detail-card {
  margin: 20rpx;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
}

.detail-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.detail-price {
  font-size: 32rpx;
  color: #e64340;
  margin-bottom: 20rpx;
}

.detail-desc {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.7;
  margin-bottom: 30rpx;
}

/* 购买统计信息 */
.purchase-stats {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 20rpx;
}

.stat-item {
  text-align: center;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

/* 已卖完提示 */
.sold-out {
  margin-top: 20rpx;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #e64340;
}

/* 例子图片和介绍 */
.example-section {
  margin: 20rpx;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.example-long-image {
  width: 100%;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f9f9f9;
}

.long-image {
  width: 100%;
  display: block;
}

.bottom-bar {
  position: fixed;
  bottom: 50rpx;
  left: 20rpx;
  right: 20rpx;
  padding: 20rpx;
  background: #ffffff;
  border-top: 1rpx solid #eeeeee;
  border-radius: 16rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  display: flex;
  gap: 20rpx;
}

.service-btn {
  background: #ffffff;
  color: #333333;
  border: 1rpx solid #dddddd;
  border-radius: 12rpx;
  flex: 1;
  height: 80rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.buy-btn {
  background: #4caf50;
  color: #ffffff;
  border-radius: 12rpx;
  flex: 1;
  height: 80rpx;
  font-size: 32rpx;
  font-weight: 600;
}