.page {
  min-height: 100vh;
  background: #f6f6f6;
}

.detail-swiper {
  width: 100%;
  height: 420rpx;
  background: #eeeeee;
}

.detail-swiper-image {
  width: 100%;
  height: 100%;
  display: block;
}

.detail-card {
  margin: 20rpx;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
}

.detail-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.detail-price {
  font-size: 32rpx;
  color: #e64340;
  margin-bottom: 20rpx;
}

.detail-desc {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.7;
  margin-bottom: 30rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 50rpx;
  left: 20rpx;
  right: 20rpx;
  padding: 20rpx;
  background: #ffffff;
  border-top: 1rpx solid #eeeeee;
  border-radius: 16rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.buy-btn {
  background: #4caf50;
  color: #ffffff;
  border-radius: 12rpx;
  width: 100%;
  height: 80rpx;
  font-size: 32rpx;
  font-weight: 600;
}