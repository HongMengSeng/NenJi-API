<view class="page">
  <swiper
    class="detail-swiper"
    indicator-dots="{{true}}"
    autoplay="{{true}}"
    circular="{{true}}"
    interval="3000"
    duration="500"
  >
    <block wx:for="{{acreDetail.swiperList}}" wx:key="id">
      <swiper-item>
        <image
          class="detail-swiper-image"
          src="{{item.image}}"
          mode="aspectFill"
        />
      </swiper-item>
    </block>
  </swiper>

  <view class="detail-card">
    <view class="detail-title">{{acreDetail.name}}</view>
    <view class="detail-price">{{acreDetail.price}}</view>
    <view class="detail-desc">{{acreDetail.description}}</view>
  </view>

  <view class="bottom-bar">
    <button class="buy-btn" bindtap="confirmPurchase">
      立即购买
    </button>
  </view>
</view>