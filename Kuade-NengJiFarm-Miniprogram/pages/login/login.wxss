/* ===================== 配色变量 =====================
   稻田黄: #D4A76A (主色)
   丝苗米白: #FDF8EE (底色/卡片)
   深稻色: #B8894E (深色点缀)
   米灰: #EDE4D0 (浅色辅助)
   ===================== */

/* 自定义导航栏（仅状态栏占位，无标题） */
.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: transparent;
  height: 0;
}

/* 页面容器 */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 50rpx;
  width: 100%;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  background-color: #FDF8EE;
}

/* 背景层 */
.bg-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.bg-image {
  width: 100%;
  height: 100%;
}

.bg-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    170deg,
    rgba(212, 167, 106, 0.2) 0%,
    rgba(253, 248, 238, 0.75) 40%,
    #FDF8EE 85%,
    #FDF8EE 100%
  );
}

/* 品牌区 */
.brand-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  position: relative;
  z-index: 2;
}

.brand-logo {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.brand-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #B8894E;
  letter-spacing: 6rpx;
  margin-bottom: 10rpx;
}

.brand-slogan {
  font-size: 22rpx;
  color: #C4AA8A;
  letter-spacing: 3rpx;
}

/* 登录卡片 */
.login-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 56rpx 44rpx;
  width: 100%;
  max-width: 600rpx;
  box-shadow:
    0 4rpx 20rpx rgba(184, 137, 78, 0.1),
    0 1rpx 4rpx rgba(0, 0, 0, 0.04);
  position: relative;
  z-index: 2;
  overflow: hidden;
}

/* 卡片顶部细线装饰 */
.login-card::before {
  content: '';
  display: block;
  height: 5rpx;
  width: 80rpx;
  background: linear-gradient(90deg, #D4A76A, #E8CBA0);
  border-radius: 3rpx;
  margin: 0 auto 40rpx;
}

/* 登录标题 */
.login-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.login-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.login-subtitle {
  font-size: 24rpx;
  color: #999;
}

/* 登录内容 */
.login-content {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 一键登录按钮 */
.login-btn-wrapper {
  width: 100%;
  position: relative;
  margin-bottom: 28rpx;
}

.phone-login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #D4A76A 0%, #C99A5A 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(212, 167, 106, 0.35);
  transition: all 0.25s ease;
  position: relative;
  overflow: hidden;
  border: none;
  outline: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.phone-login-btn::after {
  border: none;
}

.phone-login-btn:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 12rpx rgba(212, 167, 106, 0.25);
}

.phone-login-btn[disabled] {
  opacity: 0.6;
}

.phone-login-disabled {
  opacity: 0.55 !important;
  background: linear-gradient(135deg, #D0B085 0%, #C4A075 100%) !important;
  box-shadow: none !important;
}

.login-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 10;
  border-radius: 48rpx;
  background-color: transparent;
}

.login-btn-icon {
  font-size: 36rpx;
  margin-right: 14rpx;
}

.login-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 4rpx;
}

/* 安全提示 */
.security-hint {
  display: flex;
  align-items: center;
  justify-content: center;
}

.hint-icon {
  font-size: 18rpx;
  margin-right: 6rpx;
}

.hint-text {
  font-size: 18rpx;
  color: #BBB;
  letter-spacing: 1rpx;
}

/* 底部协议 */
.login-footer {
  margin-top: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  color: #CCC;
  width: 100%;
  text-align: center;
  flex-wrap: wrap;
  gap: 4rpx;
  line-height: 1.6;
  position: relative;
  z-index: 2;
}

.agreement {
  color: #CCC;
}

.agreement-link {
  color: #D4A76A;
  margin: 0 2rpx;
}

.agreement-link:active {
  opacity: 0.7;
}
