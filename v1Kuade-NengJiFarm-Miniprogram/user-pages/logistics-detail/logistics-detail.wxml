<view class="container">
  <!-- 返回按钮 -->
  <view class="nav-back" bindtap="goBack">
    <text class="back-icon">‹</text>
  </view>

  <!-- 订单信息 -->
  <view class="order-info">
    <view class="item">
      <text class="item-label">订单号：</text>
      <text class="item-value">{{orderNo}}</text>
    </view>
    <view class="item">
      <text class="item-label">快递公司：</text>
      <text class="item-value">{{deliveryName || '-'}}</text>
    </view>
    <view class="item">
      <text class="item-label">快递单号：</text>
      <text class="item-value">{{waybillId || '-'}}</text>
    </view>
  </view>

  <!-- 加载/错误状态 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-ring"></view>
    <text class="loading-text">{{loadingText}}</text>
  </view>

  <view wx:elif="{{errorMsg}}" class="error-wrap">
    <text class="error-text">{{errorMsg}}</text>
    <button class="retry-btn" bindtap="retry">重新加载</button>
  </view>

  <!-- 查看物流按钮 -->
  <view wx:else class="btn-wrap">
    <button
      class="logistics-btn"
      bindtap="viewLogistics"
      disabled="{{loading}}"
    >
      {{loading ? '加载中...' : '查看物流详情'}}
    </button>
    <text class="btn-tip">点击后将跳转至微信官方物流页面</text>
  </view>
</view>
