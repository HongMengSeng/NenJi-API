/* ============================================
   物流详情 - 暖金色风格（与订单详情页统一）
   ============================================ */

.container {
  background-color: #f2ede6;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* ============================================
   返回按钮
   ============================================ */
.nav-back {
  position: fixed;
  top: 88rpx;
  left: 20rpx;
  z-index: 200;
  width: 72rpx;
  height: 72rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.nav-back:active {
  background: rgba(0, 0, 0, 0.8);
  transform: scale(0.94);
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
  line-height: 1;
  margin-top: -4rpx;
  margin-left: -2rpx;
  font-weight: 300;
}

/* ============================================
   加载中
   ============================================ */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 300rpx 0;
}

.loading-ring {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #f0f0f0;
  border-top: 4rpx solid #d4a76a;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-txt {
  font-size: 26rpx;
  color: #999;
}

/* ============================================
   主内容
   ============================================ */
.logistics-content {
  padding: 130rpx 20rpx 20rpx;
}

/* ============================================
   状态 Banner - 暖金色渐变
   ============================================ */
.status-banner {
  background: linear-gradient(135deg, #c99a5a 0%, #e0b878 60%, #d4a96a 100%);
  border-radius: 16rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 20rpx;
  position: relative;
  overflow: hidden;
}

.status-banner::after {
  content: '';
  position: absolute;
  right: -30rpx;
  top: -30rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.status-banner-inner {
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

.status-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.status-banner-icon {
  font-size: 36rpx;
}

.status-text-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.status-main-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.1);
}

.status-sub-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ============================================
   卡片 - 与订单详情页统一
   ============================================ */
.card {
  background: #fff;
  border-radius: 14rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.card-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx 0;
}

.card-title-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-title-bar {
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(to bottom, #d4a76a, #c99a5a);
  border-radius: 3rpx;
  flex-shrink: 0;
}

.card-title-text {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 600;
}

.card-title-sub {
  font-size: 24rpx;
  color: #999;
}

.card-body {
  padding: 24rpx 28rpx 28rpx;
}

/* 行信息 */
.card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-row-column {
  flex-direction: column;
  align-items: flex-start;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.company-name {
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: 600;
}

.waybill-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.label-tag {
  font-size: 22rpx;
  color: #999;
  background-color: #f5f5f5;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.waybill-no {
  font-size: 26rpx;
  color: #666;
  font-family: 'Courier New', monospace;
  word-break: break-all;
}

.card-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 14rpx 28rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  background-color: #f5f0e8;
  color: #c99a5a;
  font-weight: 500;
  text-align: center;
  flex: 1;
}

.action-btn:active {
  background-color: #ebe2d4;
}

/* 待发货 */
.pending-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 28rpx;
  gap: 12rpx;
}

.pending-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: #fdf6ed;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.pending-icon {
  font-size: 40rpx;
}

.pending-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.pending-sub {
  font-size: 24rpx;
  color: #bbb;
}

/* ============================================
   收货地址
   ============================================ */
.addr-body {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding-top: 20rpx;
}

.addr-icon-wrap {
  width: 52rpx;
  height: 52rpx;
  background: #fdf6ed;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.addr-icon {
  font-size: 28rpx;
}

.addr-content {
  flex: 1;
  min-width: 0;
}

.addr-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.addr-name {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 600;
}

.addr-phone {
  font-size: 28rpx;
  color: #888;
}

.addr-detail {
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
}

/* ============================================
   商品信息
   ============================================ */
.goods-body {
  padding-top: 16rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-img {
  width: 110rpx;
  height: 110rpx;
  border-radius: 10rpx;
  background: #f5f5f5;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.goods-mid {
  flex: 1;
  min-width: 0;
  margin-right: 12rpx;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-qty-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.goods-qty {
  font-size: 24rpx;
  color: #bbb;
}

.goods-right {
  text-align: right;
  flex-shrink: 0;
}

.goods-price {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* ============================================
   物流轨迹 - 时间线
   ============================================ */
.trace-list {
  padding: 0;
}

.trace-item {
  display: flex;
  position: relative;
}

.trace-dot-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 30rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.trace-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background-color: #ddd;
  flex-shrink: 0;
  position: relative;
  z-index: 2;
  margin-top: 6rpx;
}

.trace-dot.active {
  width: 22rpx;
  height: 22rpx;
  background-color: #d4a76a;
  box-shadow: 0 0 0 6rpx rgba(212, 167, 106, 0.18);
  margin-top: 4rpx;
}

.trace-line {
  width: 2rpx;
  flex: 1;
  background-color: #eee;
  min-height: 56rpx;
}

.trace-content {
  flex: 1;
  padding-bottom: 36rpx;
  min-height: 50rpx;
}

.trace-item:last-child .trace-content {
  padding-bottom: 0;
}

.trace-desc {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.trace-desc.current {
  color: #c99a5a;
  font-weight: 600;
}

.trace-time-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.trace-time {
  font-size: 24rpx;
  color: #bbb;
}

.trace-item:first-child .trace-time {
  color: #c99a5a;
}

.trace-location {
  font-size: 22rpx;
  color: #ccc;
  background-color: #f5f5f5;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.trace-item:first-child .trace-location {
  background-color: #fdf6ed;
  color: #c99a5a;
}

/* 空状态 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  gap: 8rpx;
}

.empty-tip-text {
  font-size: 28rpx;
  color: #bbb;
}

.empty-tip-sub {
  font-size: 24rpx;
  color: #ddd;
}

/* ============================================
   客服悬浮按钮
   ============================================ */
.service-btn {
  position: fixed;
  bottom: 100rpx;
  right: 30rpx;
  width: 88rpx;
  height: 88rpx;
  background: #d4a76a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(212, 167, 106, 0.4);
  z-index: 9999;
  padding: 0;
  margin: 0;
  line-height: 1;
  border: none;
}

.service-btn::after {
  border: none;
}

.service-btn:active {
  transform: scale(0.92);
}

.service-icon {
  width: 36rpx;
  height: 36rpx;
  filter: brightness(0) invert(1);
}
